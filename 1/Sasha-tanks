            <div class="tank-item">
                <span>02. M1A2 Abrams (USA)</span>
                <span class="tank-price">85 UAN</span>
            </div>
            <div class="tank-item">
                <span>03. Challenger 2 (UK)</span>
                <span class="tank-price">85 UAN</span>
            </div>
            <div class="tank-item">
                <span>04. T-84 Oplot (Ukraine)</span>
                <span class="tank-price">85 UAN</span>
            </div>
            <div class="tank-item">
                <span>05. Custom LION Project</span>
                <span class="tank-price">CONTACT ADMIN</span>
            </div>
        </div>
        
        <p style="font-size: 10px; color: #4b5320; margin-top: 20px;">
            WARNING: Unauthorized distribution of this data is prohibited by military protocol.
        </p>
    </div>
</div>

<!-- Додай це в <script> -->
<script>
    function toggleCatalog(show) {
        const modal = document.getElementById('catalogModal');
        modal.style.display = show ? 'flex' : 'none';
        
        // Відтворюємо звук при відкритті/закритті
        if (typeof playClickSound === "function") {
            playClickSound();
        }
    }
</script>

</style>
</head>
<body onload="updateCoords()">

    <!-- Кнопка для активації звуку браузером -->
    <button id="activate-btn" onclick="startTerminal()">[ Active Terminal ]</button>

    <!-- Ефект сканера -->
    <div class="scanline"></div>

    <!-- Індикатори координат -->
    <div class="coord top-left">
        LAT: <span id="lat-val">50.45</span><br>
        LON: <span id="lon-val">30.52</span><br>
        SYS: ACQUIRING...
    </div>
    <div class="coord top-right">
        UNIT: HA-DIV<br>
        NET: SECURED<br>
        <span id="time-val">12:00:00</span>
    </div>
    <div class="coord bottom-left">
        TEMP: 24C<br>
        CPU: <span id="cpu-val">12</span>%<br>
        STATUS: STABLE
    </div>
    <div class="coord bottom-right">
        AUTH: ADMIN<br>
        SESSION: <span id="session-id"></span><br>
        ENC: AES-256
    </div>

    <div class="status-bar">
        System: Active | Auth: Admin | Unit: Heavy Armor Division v2.1
    </div>

    <h1>Heavy Armor Catalog</h1>

    <div class="terminal-box">
        <p>> INITIALIZING DATABASE...</p>
        <p>> ACCESSING INVENTORY...</p>
        <p>Вітаю! Тут ви знайдете найкращі зразки бронетехніки. 
        У наявності моделі з різних країн світу. 
        Якщо потрібної одиниці немає в списку — залиште запит на електронну пошту для індивідуального замовлення. oleksandr.dmitriyev@gmail.com
        Термін виконання: до 21 дня.</p>
        <p>> STATUS: READY FOR ORDERS.</p>
    </div>

    <!-- Фото, яке видає звук при кліку (Опція 2) -->
    <img src="https://p.turbosquid.com/ts-thumb/a4/ObgLYc/RJ/1/jpg/1674841488/1920x1080/fit_q87/91d3c8a7f701ee93ebfda78a52309917e8f64a93/1.jpg" 
         alt="Tank Model" 
         class="tank-preview"
         id="tank-photo">

    <!--Sasha-tanks-models-->

    <!-- Аудіо файл (Опція 2) -->
    <audio id="click-sound" preload="auto">
        <source src="https://cdn.pixabay.com/audio/2022/03/19/audio_145d5a6b0c.mp3" type="audio/mpeg">
    </audio>

    <script>
        // Елементи
        const clickSound = document.getElementById('click-sound');
        const tankPhoto = document.getElementById('tank-photo');
        const activateBtn = document.getElementById('activate-btn');

        // Опція 2: Функція відтворення звуку при взаємодії
        function playClickSound() {
            // Скидаємо звук на початок, щоб можна було клікати швидко
            clickSound.currentTime = 0; 
            clickSound.play().catch(e => console.log("Sound waiting for user interaction"));
        }

        // Функція для старту терміналу (потрібна для активації звуку в Chrome)
        function startTerminal() {
            activateBtn.style.display = 'none'; // Ховаємо кнопку
            // Тепер браузер дозволить звук
            playClickSound(); // Тестовий звук
        }

        // Опція 2: Додаємо звук при наведенні ТА кліку на танк
        tankPhoto.addEventListener('mouseenter', playClickSound);
        tankPhoto.addEventListener('click', playClickSound);


        // Опція 3: JavaScript для динамічних координат та цифр
        function updateCoords() {
            // Генерація випадкової сесії при завантаженні
            document.getElementById('session-id').innerText = Math.random().toString(16).slice(2, 8).toUpperCase();

            setInterval(() => {
                // Випадкові координати навколо України
                document.getElementById('lat-val').innerText = (44 + Math.random() * 8).toFixed(4);
                document.getElementById('lon-val').innerText = (22 + Math.random() * 18).toFixed(4);
                
                // Випадкове навантаження CPU
                document.getElementById('cpu-val').innerText = Math.floor(Math.random() * 40) + 10;
                
                // Поточний час
                const now = new Date();
                document.getElementById('time-val').innerText = now.toTimeString().split(' ')[0];

            }, 1000); // Оновлення кожну секунду
        }
    </script>

</body>
</html>
