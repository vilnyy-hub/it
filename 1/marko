<!DOCTYPE html>
<html lang="uk">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>🌸 Мій ніжний сайт</title>

<style>
body {
    font-family: Arial, sans-serif;
    margin: 0;
    overflow: hidden;
    background: linear-gradient(135deg, #ffd1dc, #ff9a9e);
}

header {
    background-color: #ff6f91;
    color: white;
    padding: 20px;
    text-align: center;
    font-size: 24px;
}

main {
    padding: 40px;
    text-align: center;
    position: relative;
    z-index: 2;
}

.card {
    background: white;
    padding: 30px;
    border-radius: 20px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    display: inline-block;
    animation: fadeIn 1.5s ease;
}

button {
    padding: 12px 25px;
    background-color: #ff6f91;
    border: none;
    color: white;
    cursor: pointer;
    border-radius: 10px;
    font-size: 16px;
    transition: 0.3s;
}

button:hover {
    background-color: #ff3e6c;
    transform: scale(1.1);
}

#counter {
    margin-top: 15px;
    font-size: 18px;
    color: #333;
}

/* 🌸 САКУРА */
.petal {
    position: fixed;
    top: -10px;
    width: 12px;
    height: 12px;
    background: radial-gradient(circle, #ffc0cb, #ff69b4);
    border-radius: 60% 40% 60% 40%;
    opacity: 0.8;
    animation: fall linear infinite;
    z-index: 1;
}

@keyframes fall {
    to {
        transform: translateY(110vh) rotate(360deg);
    }
}

/* ✨ Поява */
@keyframes fadeIn {
    from {
        opacity: 0;
        transform: translateY(30px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}
</style>
</head>

<body>

<header>
    <h1>🌸 Мій ніжний сайт</h1>
</header>

<main>
    <div class="card">
        <p>Сакура падає прямо зараз 😍</p>

        <button onclick="showMessage()">Натисни мене</button>

        <div id="counter">Натиснули: 0 разів</div>
    </div>
</main>

<script>
let count = 0;

function showMessage() {
    count++;
    document.getElementById("counter").innerText = "Натиснули: " + count + " разів";
}

/* 🌸 САКУРА (оптимізована) */
let petalsCount = 0;
const maxPetals = 40;

function createPetal() {
    if (petalsCount >= maxPetals) return;

    const petal = document.createElement("div");
    petal.classList.add("petal");

    petal.style.left = Math.random() * 100 + "vw";
    petal.style.animationDuration = (4 + Math.random() * 4) + "s";
    petal.style.opacity = Math.random();

    document.body.appendChild(petal);
    petalsCount++;

    setTimeout(() => {
        petal.remove();
        petalsCount--;
    }, 8000);
}

setInterval(createPetal, 250);
</script>

</body>
</html>
